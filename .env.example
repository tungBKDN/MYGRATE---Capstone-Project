# ── LLM Provider ──
# Options: groq, ollama
PROVIDER=groq

# ── Groq Config ──
GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL="llama-3.3-70b-versatile"

# ── Ollama Config ──
OLLAMA_MODEL="llama3:70b"
OLLAMA_BASE_URL="https://ollama.com"
# OLLAMA_KEY is optional — Ollama doesn't require auth by default
# OLLAMA_KEY=""

# ── LangSmith Config ──
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="mygrate-project"